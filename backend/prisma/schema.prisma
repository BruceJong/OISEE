// OISee Prisma Schema · MVP 闭环版
// ============================================================
// 范围说明：本 schema 包含 CMS 快速管理、AI 生图任务队列及设置模块。
// 完整设计见 tech-design/02-数据模型设计.md 与 09-CMS技术设计.md。
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("OISEE_DATABASE_URL")
}

// ============================================================
// 枚举
// ============================================================

enum Difficulty {
  L1
  L2
  L3
}

enum Subject {
  PHYSICS
  CHEMISTRY
  BIOLOGY
  GEOGRAPHY
  OTHER
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ============================================================
// 管理员
// ============================================================

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  email        String?  @unique
  isActive     Boolean  @default(true)
  // MVP 阶段仅 'superadmin' 一个角色，存字符串字段；后续切到 RBAC 多对多
  role         String   @default("superadmin")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastLoginAt  DateTime?
}

// ============================================================
// 终端用户（前台账号）
// ============================================================

model User {
  id            String    @id @default(cuid())
  username      String?   @unique   // 账密注册必填；纯微信用户可空
  passwordHash  String?             // 微信用户可空
  nickname      String              // 显示名
  avatar        String              // 预设头像 key，如 "fox"
  phone         String?
  wechatOpenId  String?   @unique   // 微信(模拟)唯一标识

  // 学习画像
  age           Int?
  learningStage String?             // 用户自填（自由文本/下拉）
  gradeStage    String?             // 思考模型结果: PRESCHOOL/PRIMARY/MIDDLE/HIGH/ADULT

  isActive      Boolean   @default(true)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?
}

// ============================================================
// 一级场景（场景组）
// ============================================================

model SceneGroup {
  id             String        @id @default(cuid())
  slug           String        @unique
  name           String        @unique              // "家" / "校园" / "户外" / "城市"
  description    String?
  mapImageUrl    String?                            // 一级地图背景图（历史字段，已迁移到 AdminSetting['world_map']）
  mapImagePrompt String?                            // AI 文生图提示词（历史字段）
  mapPosition    Json?                              // {x, y, radius} 百分比，该一级场景在世界地图上的位置
  iconKind       String?                            // home/school/park/hospital/mall
  themeColor     String?                            // sun/ocean/leaf/coral/berry
  sortOrder      Int           @default(0)
  status         ContentStatus @default(DRAFT)

  // ── 解锁逻辑 ──
  isLocked         Boolean @default(false)          // 是否锁定（false=默认开放）
  unlockHint       String?                          // 锁定提示文案
  unlockConditions Json?                            // { type: 'after_groups', groupIds: ['xxx', 'yyy'] }

  scenes         Scene[]

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  @@index([status, sortOrder])
}

// ============================================================
// 二级场景
// ============================================================

model Scene {
  id            String        @id @default(cuid())
  slug          String        @unique
  name          String
  groupName     String                                  // 兼容字段，新记录请用 sceneGroupId
  sceneGroupId  String?
  sceneGroup    SceneGroup?   @relation(fields: [sceneGroupId], references: [id])
  description   String?
  coverUrl      String?
  sceneImageUrl String?                                 // 2.5D 大图
  sceneImagePrompt String?                              // AI 文生图提示词
  iconKind      String?                                 // home/school/park/hospital/mall
  themeColor    String?                                 // sun/ocean/leaf/coral/berry
  isDefault     Boolean       @default(false)
  unlockHint    String?
  isLocked      Boolean       @default(false)
  unlockConditions Json?                                // { type: 'after_groups', groupIds: [...] }
  mapPosition   Json?                                   // {x, y} 百分比，在一级地图上的位置（不再编辑，遗留字段）
  status        ContentStatus @default(DRAFT)
  sortOrder     Int           @default(0)

  items         Item[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  @@index([status, sortOrder])
  @@index([sceneGroupId])
}

// ============================================================
// 物品
// ============================================================

model Item {
  id                  String   @id @default(cuid())
  slug                String   @unique
  name                String
  sceneId             String
  scene               Scene    @relation(fields: [sceneId], references: [id])

  coverUrl            String?
  itemImageUrl        String?
  iconUrl             String?    // 简笔卡通图标，用于紧凑预览（如知识点详情首屏的关联物品）
  svgSymbolId         String?

  shortDesc           String
  // {"L1": "...", "L2": "...", "L3": "..."}
  principleByLevel    Json     @default("{}")

  videoTitle          String?
  videoDurationSec    Int?
  principleVideoUrl   String?
  explodedImageUrl    String?
  parts               Json?    // [{no, name, desc, x, y}]
  scenePosition       Json?    // {x, y, width, height} 百分比

  status              ContentStatus @default(DRAFT)
  sortOrder           Int      @default(0)

  knowledgePoints     ItemKnowledgePoint[]
  experiments         ExperimentItem[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  deletedAt           DateTime?

  @@index([sceneId, sortOrder])
  @@index([status])
}

// ============================================================
// 知识点
// ============================================================

model KnowledgePoint {
  id              String        @id @default(cuid())
  slug            String        @unique
  name            String
  subject         Subject
  difficulty      Difficulty
  summary         String?
  // MVP 用纯文本/Markdown 字符串；后续切到 TipTap JSON
  content         String
  illustrationUrl String?

  // 知识点介绍视频（与 Item 视频字段对齐）
  videoTitle       String?
  videoDurationSec Int?
  videoUrl         String?

  status          ContentStatus @default(DRAFT)

  items           ItemKnowledgePoint[]
  experiments     ExperimentKnowledgePoint[]
  quizQuestions   QuizQuestion[]
  // 自关联（知识网络）
  relatedFrom     KnowledgeRelation[] @relation("fromKp")
  relatedTo       KnowledgeRelation[] @relation("toKp")

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  @@index([subject, difficulty])
  @@index([status])
}

// ============================================================
// 考考你 · 知识点小测题（多选一）
// ============================================================
model QuizQuestion {
  id               String        @id @default(cuid())
  knowledgePointId String
  knowledgePoint   KnowledgePoint @relation(fields: [knowledgePointId], references: [id], onDelete: Cascade)

  question         String        // 题干
  choices          Json          // string[] 4 个选项
  correctIndex     Int           // 正确答案下标 0-3
  explanation      String?       // 答完后展示的解析
  difficulty       Difficulty    @default(L1)

  status           ContentStatus @default(PUBLISHED)
  sortOrder        Int           @default(0)

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([knowledgePointId, sortOrder])
  @@index([status])
}

// ============================================================
// 多对多关联
// ============================================================

model ItemKnowledgePoint {
  itemId           String
  knowledgePointId String
  sortOrder        Int    @default(0)

  item             Item           @relation(fields: [itemId], references: [id], onDelete: Cascade)
  knowledgePoint   KnowledgePoint @relation(fields: [knowledgePointId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now())

  @@id([itemId, knowledgePointId])
  @@index([knowledgePointId])
}

// ============================================================
// 实验
// ============================================================

model Experiment {
  id             String        @id @default(cuid())
  slug           String        @unique
  name           String
  difficulty     Difficulty
  durationMin    Int           @default(10)
  needParent     Boolean       @default(false)
  materialType   String?                               // "家用物品" / "材料包"
  description    String
  materialsHome  Json?                                 // string[]
  materialsKit   Json?                                 // string[]
  safety         String?
  coverUrl       String?
  videoUrl       String?
  status         ContentStatus @default(DRAFT)
  sortOrder      Int           @default(0)

  items          ExperimentItem[]
  knowledgePoints ExperimentKnowledgePoint[]

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  @@index([status, difficulty])
}

model ExperimentItem {
  experimentId String
  itemId       String

  experiment   Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  item         Item       @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([experimentId, itemId])
}

model ExperimentKnowledgePoint {
  experimentId     String
  knowledgePointId String

  experiment       Experiment     @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  knowledgePoint   KnowledgePoint @relation(fields: [knowledgePointId], references: [id], onDelete: Cascade)

  @@id([experimentId, knowledgePointId])
}

model KnowledgeRelation {
  fromId       String
  toId         String
  relationType String?

  from         KnowledgePoint @relation("fromKp", fields: [fromId], references: [id], onDelete: Cascade)
  to           KnowledgePoint @relation("toKp", fields: [toId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())

  @@id([fromId, toId])
  @@index([toId])
}

// ============================================================
// AI 生图任务队列
// ============================================================

model AiTask {
  id           String   @id @default(cuid())
  // 实体类型：scene_group / scene / item / knowledge_point / experiment
  entityType   String
  entityId     String
  // 生成目的：map_image / scene_image / cover / item_image / exploded / illustration / video_cover
  purpose      String
  prompt       String   @db.Text
  modelId      String   // 对应 AdminSetting 中配置的模型 ID
  // PENDING / RUNNING / DONE / FAILED
  status       String   @default("PENDING")
  progress     Int      @default(0)  // 0-100
  resultUrl    String?
  errorMessage String?
  adminId      String

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([status])
  @@index([adminId, createdAt(sort: Desc)])
}

// ============================================================
// 管理员设置（模型 & API Key 等键值对存储）
// ============================================================

model AdminSetting {
  id        String   @id @default(cuid())
  key       String   @unique   // e.g. "ai_models" / "ai_default_model"
  value     Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
