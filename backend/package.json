{
  "name": "@oisee/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "node ./node_modules/@nestjs/cli/bin/nest.js build && node --watch dist/main.js",
    "dev:tsx": "tsx watch --tsconfig tsconfig.json src/main.ts",
    "dev:watch": "nest build && nest start --watch --preserveWatchOutput",
    "build": "nest build",
    "start": "node dist/main",
    "typecheck": "tsc --noEmit",
    "prisma": "prisma",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/serve-static": "^4.0.2",
    "@oisee/shared": "workspace:*",
    "@prisma/client": "^5.20.0",
    "ali-oss": "^6.23.0",
    "argon2": "^0.41.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@types/ali-oss": "^6.23.3",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^5.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
