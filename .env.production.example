# ====================================================================
# OISee 生产环境变量模板
# 用法：复制到服务器 /opt/oisee/.env.production 并逐项替换 __CHANGE_ME__
#   cp .env.production.example /opt/oisee/.env.production
#   chmod 600 /opt/oisee/.env.production
# 强随机值生成：openssl rand -hex 32
# ====================================================================

# ---- PostgreSQL（由 docker-compose 起的 postgres 容器使用）----
OISEE_DB_USER=oisee
OISEE_DB_PASSWORD=__CHANGE_ME_strong_db_password__
OISEE_DB_NAME=oisee
# 注意：host 必须是服务名 postgres；账号/库名要与上面三项一致
OISEE_DATABASE_URL=postgresql://oisee:__CHANGE_ME_strong_db_password__@postgres:5432/oisee

# ---- API ----
OISEE_NODE_ENV=production
OISEE_PORT=3000

# ---- JWT 密钥（openssl rand -hex 32）----
OISEE_JWT_USER_SECRET=__CHANGE_ME_32bytes_hex__
OISEE_JWT_ADMIN_SECRET=__CHANGE_ME_32bytes_hex__
OISEE_JWT_ACCESS_TTL=1d
OISEE_JWT_REFRESH_TTL=30d

# ---- 主密钥（API Key 加密存储用，openssl rand -hex 32）----
OISEE_SECRET_MASTER_KEY=__CHANGE_ME_64hex__

# ---- 站点来源（同源反代）----
# 上线初期用 IP 测试就填 http://<ECS公网IP>；备案+域名+HTTPS 后改成 https://你的域名
OISEE_WEB_ORIGIN=https://oisee.com
OISEE_ADMIN_ORIGIN=https://oisee.com

# ---- 媒体公开地址（经 Nginx 回源 API；与上面同域名/IP）----
OISEE_UPLOAD_BASE_URL=https://oisee.com/uploads
OISEE_VIDEO_BASE_URL=https://oisee.com/video
OISEE_DEMO_VIDEO=sample_video.mp4
# OISEE_UPLOAD_DIR / OISEE_VIDEO_DIR 由 docker-compose 注入，请勿在此设置

# ---- 首次部署超管 seed（仅首次用到，之后可改密码）----
OISEE_SEED_SUPERADMIN_USERNAME=admin
OISEE_SEED_SUPERADMIN_PASSWORD=__CHANGE_ME_admin_password__
