# ====================================================================
# OISee 开发环境变量示例
# 复制此文件为 .env 并按需修改
# ====================================================================

# ---- 数据库 ----
OISEE_DATABASE_URL=postgresql://oisee:oisee_dev@localhost:5432/oisee_dev

# ---- API 服务 ----
OISEE_NODE_ENV=development
OISEE_PORT=3000

# ---- JWT 密钥（生产请替换为强随机值）----
# 生成命令：openssl rand -hex 32
OISEE_JWT_USER_SECRET=dev_user_secret_change_in_production_aaaaaaaaaaaaaaaa
OISEE_JWT_ADMIN_SECRET=dev_admin_secret_change_in_production_bbbbbbbbbbbbbbbb
OISEE_JWT_ACCESS_TTL=15m
OISEE_JWT_REFRESH_TTL=30d

# ---- 主密钥（用于 API Key 加密存储）----
# 生成命令：openssl rand -hex 32
OISEE_SECRET_MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ---- CORS 来源 ----
OISEE_WEB_ORIGIN=http://localhost:5173
OISEE_ADMIN_ORIGIN=http://localhost:5174

# ---- 本地文件上传（替代 OSS）----
# 相对项目根：data/uploads
# 后端启动 cwd 是 code/apps/api，所以这里写相对该位置的路径
OISEE_UPLOAD_DIR=../../../data/uploads
OISEE_UPLOAD_BASE_URL=http://localhost:3000/uploads

# ---- 超管 seed（仅首次部署用到）----
OISEE_SEED_SUPERADMIN_USERNAME=admin
OISEE_SEED_SUPERADMIN_PASSWORD=admin123456
